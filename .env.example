# Database
DATABASE_URL="postgresql://opcwc:opcwc@localhost:5432/opcwc?schema=public"

# Auth.js
AUTH_SECRET="generate-a-random-secret-here"
AUTH_URL="http://localhost:3000"

# Gaode (高德) API
GAODE_JS_API_KEY="your-gaode-js-api-key"
GAODE_WEB_API_KEY="your-gaode-web-api-key"

# Optional: OSM Overpass (no key needed, but rate-limited)
OVERpass_API_URL="https://overpass-api.de/api/interpreter"

# Redis (optional, post-MVP)
REDIS_URL="redis://localhost:6379"
